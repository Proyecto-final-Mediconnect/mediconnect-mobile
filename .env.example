# Variables de entorno del cliente mobile (Expo).
# 3.4.11: los secretos reales NUNCA se commitean. Este archivo documenta
# la lista de variables necesarias SIN valores. Copialo a `.env` localmente.
#
# Convención Expo: solo las variables con prefijo EXPO_PUBLIC_ se exponen al
# bundle JS del cliente. NO pongas secretos de servidor acá.

# URL base de la API REST del backend (NestJS).
EXPO_PUBLIC_API_URL=

# Entorno lógico de la app: development | staging | production.
EXPO_PUBLIC_ENV=

# --- Solo para builds/CI con EAS (no se exponen al cliente) ---
# Token de acceso de Expo para EAS Build en CI (se inyecta como secret en CI).
# EXPO_TOKEN=
